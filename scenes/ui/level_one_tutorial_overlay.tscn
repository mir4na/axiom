[node name="AxiomPage01" type="Label" parent="TutorialContent" unique_id=364592851]
layout_mode = 0
text = "AXIOM records your recent movement and facing over time."

[node name="AxiomPage02" type="Label" parent="TutorialContent" unique_id=1100876669]
layout_mode = 0
text = "You can rewind to any recorded moment and commit that state as your new position."

[node name="AxiomPage03" type="Label" parent="TutorialContent" unique_id=168359684]
layout_mode = 0
text = "Let's run a quick rewind tutorial before the final sprint."

