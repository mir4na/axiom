layout_mode = 0
text = "[R] ACTIVATE"

[node name="HintRewindMove" type="Label" parent="TutorialContent" unique_id=551205457]
layout_mode = 0
text = "[R/F] KEEP MOVING THE POINTER"

[node name="HintRewindCommit" type="Label" parent="TutorialContent" unique_id=1281848779]
layout_mode = 0
text = "[SPACE] JUMP TO SELECTED MOMENT"

[node name="PromptRewindActivate" type="Label" parent="TutorialContent" unique_id=949319561]
layout_mode = 0
text = "Press R to activate Axiom rewind mode."

[node name="PromptRewindStep01" type="Label" parent="TutorialContent" unique_id=376151939]
layout_mode = 0
text = "That split is too wide for a normal jump. You cannot clear it without rewinding."

[node name="PromptRewindStep02" type="Label" parent="TutorialContent" unique_id=1505744746]
layout_mode = 0
text = "Remember when you grabbed the keycard in the kitchen? Reposition to the recorded coordinates from that moment, then cross the split and reach the hole."

[node name="CalloutRewindBase" type="Label" parent="TutorialContent" unique_id=1307412585]
layout_mode = 0
text = "Timeline Pointer
Hold R = past, hold F = forward. Keep moving the pointer to browse recorded moments."

[node name="CalloutWarningBase" type="Label" parent="TutorialContent" unique_id=2091933133]
layout_mode = 0
text = "Warning
If rewind stays active for over 10 seconds, the system overloads and stuns you."

[node name="CalloutCommitBase" type="Label" parent="TutorialContent" unique_id=620892822]
layout_mode = 0
text = "Commit Rule
Press SPACE to jump to the selected state. Any state ahead of the pointer is permanently erased."

[node name="CalloutRewindStep01" type="Label" parent="TutorialContent" unique_id=251688385]
layout_mode = 0
text = "Timeline Pointer
Shift backward until the pointer reaches the kitchen keycard coordinates."

[node name="CalloutCommitStep02" type="Label" parent="TutorialContent" unique_id=1915043574]
layout_mode = 0
text = "Commit Now
Jump to those recorded kitchen coordinates, then cross the split and reach the hole."
